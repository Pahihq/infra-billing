// Multi-file schema: config blocks here, one file per model.
// camelCase fields -> snake_case DB via @map on every field; plural table via @@map. Money is Decimal(14,2), never Float.

generator client {
  provider     = "prisma-client"
  output       = "../../src/generated/prisma"
  runtime      = "nodejs"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}
