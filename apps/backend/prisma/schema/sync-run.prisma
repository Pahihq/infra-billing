model SyncRun {
  id BigInt @id @default(autoincrement()) @map("id")

  providerUuid  String    @map("provider_uuid")
  status        String    @map("status")
  servicesFound Int       @default(0) @map("services_found")
  error         String?   @map("error")
  startedAt     DateTime  @default(now()) @map("started_at")
  finishedAt    DateTime? @map("finished_at")

  provider Provider @relation(fields: [providerUuid], references: [uuid], onDelete: Cascade)

  @@index([providerUuid, startedAt], map: "sync_runs_provider_started_idx")
  @@map("sync_runs")
}
